<div class="space-y-8">
  <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
    <div>
      <h1 class="text-3xl font-bold text-slate-900">Freelancer Dashboard</h1>
      <p class="mt-2 text-sm text-slate-600">Track your proposals, contracts, earnings, and reviews in one place.</p>
    </div>

    <%= link_to "Edit Profile", edit_freelancer_profile_path, class: "inline-flex items-center justify-center rounded-full bg-emerald-600 px-5 py-2 font-semibold text-white hover:bg-emerald-700" %>
  </div>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6">
    <div class="rounded-xl border border-slate-200 bg-white p-5 text-center shadow-sm">
      <h5 class="text-sm font-medium text-slate-500">Total Earned</h5>
      <h2 class="mt-2 text-3xl font-bold text-emerald-600">$<%= @total_earned || 0 %></h2>
    </div>

    <div class="rounded-xl border border-slate-200 bg-white p-5 text-center shadow-sm">
      <h5 class="text-sm font-medium text-slate-500">Proposals</h5>
      <h2 class="mt-2 text-3xl font-bold text-slate-900"><%= @proposals_count %></h2>
    </div>

    <div class="rounded-xl border border-slate-200 bg-white p-5 text-center shadow-sm">
      <h5 class="text-sm font-medium text-slate-500">Pending</h5>
      <h2 class="mt-2 text-3xl font-bold text-amber-600"><%= @pending_proposals_count %></h2>
    </div>

    <div class="rounded-xl border border-slate-200 bg-white p-5 text-center shadow-sm">
      <h5 class="text-sm font-medium text-slate-500">Accepted</h5>
      <h2 class="mt-2 text-3xl font-bold text-green-600"><%= @accepted_proposals_count %></h2>
    </div>

    <div class="rounded-xl border border-slate-200 bg-white p-5 text-center shadow-sm">
      <h5 class="text-sm font-medium text-slate-500">Unread Messages</h5>
      <h2 class="mt-2 text-3xl font-bold text-red-600"><%= @unread_messages_count %></h2>
    </div>

    <div class="rounded-xl border border-slate-200 bg-white p-5 text-center shadow-sm">
      <h5 class="text-sm font-medium text-slate-500">Reviews</h5>
      <h2 class="mt-2 text-3xl font-bold text-slate-900"><%= @total_reviews %></h2>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <%= link_to jobs_path, class: "rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:bg-slate-50" do %>
      <div class="text-sm font-medium text-slate-600">View All Jobs</div>
      <div class="mt-1 text-2xl font-bold text-slate-900">Browse</div>
    <% end %>

    <%= link_to payments_path, class: "rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:bg-slate-50" do %>
      <div class="text-sm font-medium text-slate-600">Payments</div>
      <div class="mt-1 text-2xl font-bold text-slate-900">$<%= @total_earned || 0 %></div>
    <% end %>

    <%= link_to conversations_path, class: "rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:bg-slate-50" do %>
      <div class="text-sm font-medium text-slate-600">Messages</div>
      <div class="mt-1 text-2xl font-bold text-slate-900"><%= @unread_messages_count %></div>
    <% end %>

    <%= link_to contracts_path, class: "rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:bg-slate-50" do %>
      <div class="text-sm font-medium text-slate-600">Contracts</div>
      <div class="mt-1 text-2xl font-bold text-slate-900"><%= @all_contracts_count %></div>
    <% end %>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
    <aside class="space-y-6 lg:col-span-1">
      <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="p-6 text-center">
          <% if @freelancer.profile_picture.present? %>
            <img src="<%= @freelancer.profile_picture %>" class="mx-auto mb-4 h-36 w-36 rounded-full object-cover" alt="Profile">
          <% else %>
            <div class="mx-auto mb-4 h-36 w-36 rounded-full bg-slate-200"></div>
          <% end %>

          <h3 class="text-lg font-semibold text-slate-900"><%= @freelancer.name %></h3>
          <p class="mt-2 text-sm text-slate-500"><%= @freelancer.bio.presence || "No bio yet" %></p>

          <div class="mt-4 space-y-2 text-left text-sm text-slate-700">
            <p><span class="font-medium">Hourly:</span> $<%= @freelancer.hourly_rate.presence || "Not set" %>/hr</p>
            <p><span class="font-medium">Hours/Week:</span> <%= @freelancer.hours_per_week.presence || "Not set" %></p>
            <p><span class="font-medium">Rating:</span> <%= @freelancer.average_rating %>/5 (<%= @freelancer.review_count %>)</p>
          </div>

          <div class="mt-5">
            <%= link_to "Edit Profile", edit_freelancer_profile_path, class: "inline-flex w-full items-center justify-center rounded-full bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700" %>
          </div>
        </div>
      </div>

      <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="mb-4 flex items-center justify-between">
          <h4 class="text-lg font-semibold text-slate-900">Active Contracts</h4>
          <%= link_to "View All", contracts_path, class: "text-sm font-medium text-emerald-700 hover:text-emerald-800" %>
        </div>

        <% if @contracts.any? %>
          <div class="space-y-4">
            <% @contracts.each do |contract| %>
              <div class="border-b border-slate-200 pb-4 last:border-b-0 last:pb-0">
                <p class="font-medium text-slate-900"><%= contract.job.title %></p>
                <p class="mt-1 text-xs text-slate-500"><%= contract.job.user.name %></p>
                <div class="mt-2">
                  <%= link_to "View", contract_path(contract), class: "text-sm font-medium text-emerald-700 hover:text-emerald-800" %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-slate-500">No active contracts.</p>
        <% end %>
      </div>
    </aside>

    <section class="space-y-6 lg:col-span-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
  <h3 class="mb-4 text-lg font-semibold text-slate-900">Received Proposals</h3>
  <p class="text-sm text-slate-600">Monitor all proposals you've submitted to jobs.</p>
</div>

        <% if @proposals.any? %>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200 text-sm">
              <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
                <tr>
                  <th class="px-4 py-3">Job</th>
                  <th class="px-4 py-3">Status</th>
                  <th class="px-4 py-3">Submitted</th>
                  <th class="px-4 py-3">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <% @proposals.each do |proposal| %>
                  <tr class="hover:bg-slate-50">
                    <td class="px-4 py-3 font-medium text-slate-900">
                      <%= link_to proposal.job.title, job_path(proposal.job), class: "text-emerald-700 hover:text-emerald-800" %>
                    </td>
                    <td class="px-4 py-3">
                      <% status_class =
                        case proposal.status
                        when "pending" then "bg-amber-100 text-amber-800"
                        when "accepted" then "bg-green-100 text-green-800"
                        when "rejected" then "bg-red-100 text-red-800"
                        else "bg-slate-100 text-slate-800"
                        end %>

                        <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold <%= status_class %>">
  <%= (proposal.status || 'pending').titleize %>
</span>
                    </td>
                    <td class="px-4 py-3 text-slate-600"><%= proposal.created_at.strftime("%B %d, %Y") %></td>
                                <td class="px-4 py-3">
  <div class="flex flex-wrap gap-2">
    <% if proposal.status == 'accepted' && proposal.contract.present? %>
      <%= link_to "Contract", contract_path(proposal.contract), class: "rounded-md bg-emerald-100 px-3 py-1.5 text-xs font-semibold text-emerald-800 hover:bg-emerald-200" %>
    <% end %>
    <%= link_to "Job", job_path(proposal.job), class: "rounded-md bg-blue-100 px-3 py-1.5 text-xs font-semibold text-blue-800 hover:bg-blue-200" %>
  </div>
</td>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="rounded-lg border border-slate-200 bg-slate-50 p-4 text-slate-600">
            No proposals submitted yet.
          </div>
        <% end %>
      </div>

      <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="mb-4 flex items-center justify-between">
          <h4 class="text-lg font-semibold text-slate-900">Skills</h4>
          <%= link_to "Add Skill", edit_freelancer_profile_path, class: "text-sm font-medium text-emerald-700 hover:text-emerald-800" %>
        </div>

        <% if @skills.any? %>
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <% @skills.each do |skill| %>
              <div class="rounded-lg border border-slate-200 p-4">
                <h6 class="font-medium text-slate-900"><%= skill.name %></h6>
                <p class="mt-1 text-sm text-slate-500"><%= skill.proficiency.capitalize %></p>
                <div class="mt-3 flex gap-3">
                  <%= link_to "Edit", edit_skill_path(skill), class: "text-sm font-medium text-amber-700 hover:text-amber-800" %>
                  <%= link_to "Delete", skill_path(skill), method: :delete, data: { confirm: "Sure?" }, class: "text-sm font-medium text-red-700 hover:text-red-800" %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-slate-500">
            No skills added yet.
            <%= link_to "Add your first skill", edit_freelancer_profile_path, class: "font-medium text-emerald-700 hover:text-emerald-800" %>
          </p>
        <% end %>
      </div>

      <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="mb-4 border-b border-slate-200 pb-4">
          <h4 class="text-lg font-semibold text-slate-900">Recent Reviews</h4>
        </div>

        <% if @reviews.any? %>
          <div class="space-y-4">
            <% @reviews.each do |review| %>
              <div class="border-b border-slate-200 pb-4 last:border-b-0 last:pb-0">
                <div class="flex items-center justify-between">
                  <h6 class="font-medium text-slate-900"><%= review.reviewer.name %></h6>
                  <span class="rounded-full bg-blue-100 px-2.5 py-1 text-xs font-semibold text-blue-800"><%= review.rating %>/5</span>
                </div>
                <p class="mt-2 text-sm text-slate-700"><%= review.comment %></p>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-slate-500">No reviews yet.</p>
        <% end %>
      </div>
    </section>
  </div>
</div>