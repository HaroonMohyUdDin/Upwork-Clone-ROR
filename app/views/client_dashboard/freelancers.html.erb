<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-3xl font-bold text-slate-900">Browse Talented Freelancers</h1>
  </div>

  <!-- Search & Filter -->
  <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
    <%= form_with url: client_freelancers_path, method: :get, local: true, class: "flex gap-4" do |f| %>
      <%= f.text_field :search, placeholder: "Search by name or skill...", class: "form-input flex-1" %>
      <%= f.submit "Search", class: "btn btn-primary" %>
    <% end %>
  </div>

  <!-- Freelancers Grid -->
  <% if @freelancers.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @freelancers.each do |freelancer| %>
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-lg transition-shadow">
          <!-- Profile Header -->
          <div class="flex items-start gap-4 mb-4">
            <div class="w-16 h-16 rounded-full bg-emerald-600 text-white flex items-center justify-center text-lg font-bold flex-shrink-0">
              <%= freelancer.name.first.upcase %>
            </div>
            <div class="flex-1">
              <h3 class="text-lg font-semibold text-slate-900"><%= freelancer.name %></h3>
              <p class="text-sm text-slate-600"><%= freelancer.role.titleize %></p>
            </div>
          </div>

          <!-- Bio -->
          <p class="text-sm text-slate-600 mb-3"><%= truncate(freelancer.bio, length: 100) || "No bio yet" %></p>

          <!-- Rating -->
          <div class="flex items-center gap-2 mb-3">
            <span class="text-sm font-semibold text-emerald-600">
              ★ <%= freelancer.average_rating %>/5.0
            </span>
            <span class="text-xs text-slate-500">(<%= freelancer.review_count %> reviews)</span>
          </div>

          <!-- Hourly Rate -->
          <% if freelancer.hourly_rate %>
            <div class="mb-4">
              <p class="text-sm text-slate-700">
                <span class="font-semibold">$<%= freelancer.hourly_rate %></span>
                <span class="text-slate-600">/hour</span>
              </p>
            </div>
          <% end %>

          <!-- Hours Per Week -->
          <% if freelancer.hours_per_week %>
            <div class="mb-4">
              <p class="text-sm text-slate-600">
                Available: <span class="font-semibold"><%= freelancer.hours_per_week %> hrs/week</span>
              </p>
            </div>
          <% end %>

          <!-- Skills -->
          <% if freelancer.skills.any? %>
            <div class="mb-4">
              <p class="text-xs font-semibold text-slate-700 mb-2">Skills:</p>
              <div class="flex flex-wrap gap-2">
                <% freelancer.skills.limit(3).each do |skill| %>
                  <span class="inline-block bg-slate-100 text-slate-800 text-xs px-2 py-1 rounded">
                    <%= skill.name %>
                  </span>
                <% end %>
                <% if freelancer.skills.count > 3 %>
                  <span class="text-xs text-slate-500">+<%= freelancer.skills.count - 3 %> more</span>
                <% end %>
              </div>
            </div>
          <% end %>

          <!-- Actions -->
          <div class="flex gap-2 pt-4 border-t border-slate-200">
            <%= link_to "View Profile", user_path(freelancer), class: "flex-1 rounded-lg border border-slate-300 px-3 py-2 text-center text-sm font-medium text-slate-700 hover:bg-slate-50" %>
            <%= link_to "Message", conversations_path(receiver_id: freelancer.id), method: :post, class: "flex-1 rounded-lg bg-emerald-600 px-3 py-2 text-center text-sm font-medium text-white hover:bg-emerald-700" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-xl border border-slate-200 bg-white p-12 text-center">
      <p class="text-slate-600 mb-4">No freelancers found.</p>
    </div>
  <% end %>
</div>