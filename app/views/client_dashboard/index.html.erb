<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-3xl font-bold text-slate-900">Client Dashboard</h1>
    <%= link_to "Post New Job", new_job_path, class: "inline-flex rounded-full bg-emerald-600 px-5 py-2 font-medium text-white hover:bg-emerald-700" %>
  </div>

  <!-- Stats Grid -->
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-5">
    <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm hover:shadow-md transition-shadow">
      <h5 class="text-sm font-medium text-slate-500">Posted Jobs</h5>
      <h2 class="mt-2 text-3xl font-bold text-slate-900"><%= @jobs.count %></h2>
    </div>

    <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm hover:shadow-md transition-shadow">
      <h5 class="text-sm font-medium text-slate-500">Active Jobs</h5>
      <h2 class="mt-2 text-3xl font-bold text-emerald-600"><%= @active_jobs.count %></h2>
    </div>

    <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm hover:shadow-md transition-shadow">
      <h5 class="text-sm font-medium text-slate-500">Pending Proposals</h5>
      <h2 class="mt-2 text-3xl font-bold text-blue-600"><%= @pending_proposals %></h2>
    </div>

    <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm hover:shadow-md transition-shadow">
      <h5 class="text-sm font-medium text-slate-500">Active Contracts</h5>
      <h2 class="mt-2 text-3xl font-bold text-purple-600"><%= @active_contracts %></h2>
    </div>

    <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm hover:shadow-md transition-shadow">
      <h5 class="text-sm font-medium text-slate-500">Total Spent</h5>
      <h2 class="mt-2 text-3xl font-bold text-slate-900">$<%= @total_spent %></h2>
    </div>
  </div>

  <!-- Quick Links -->
  <!-- Quick Links -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
  <div class="rounded-lg border border-slate-200 bg-white p-4 text-center hover:bg-slate-50 transition-colors">
    <div class="text-sm font-medium text-slate-600">Pending Proposals</div>
    <div class="text-2xl font-bold text-slate-900 mt-1"><%= @pending_proposals %></div>
  </div>

  <%= link_to client_contracts_path, class: "rounded-lg border border-slate-200 bg-white p-4 text-center hover:bg-slate-50 transition-colors" do %>
    <div class="text-sm font-medium text-slate-600">Active Contracts</div>
    <div class="text-2xl font-bold text-slate-900 mt-1"><%= @active_contracts %></div>
  <% end %>

  <%= link_to client_payments_path, class: "rounded-lg border border-slate-200 bg-white p-4 text-center hover:bg-slate-50 transition-colors" do %>
    <div class="text-sm font-medium text-slate-600">This Month</div>
    <div class="text-2xl font-bold text-slate-900 mt-1">$<%= @month_spent %></div>
  <% end %>

  <%= link_to client_freelancers_path, class: "rounded-lg border border-slate-200 bg-white p-4 text-center hover:bg-slate-50 transition-colors" do %>
    <div class="text-sm font-medium text-slate-600">Browse Talents</div>
    <div class="text-2xl font-bold text-slate-900 mt-1">→</div>
  <% end %>
</div>

  <!-- Recent Jobs Table -->
  <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
    <h3 class="mb-4 text-xl font-semibold text-slate-900">Recent Jobs</h3>
    <% if @jobs.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
          <thead class="bg-slate-50">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-slate-600">Title</th>
              <th class="px-4 py-3 text-left font-semibold text-slate-600">Status</th>
              <th class="px-4 py-3 text-left font-semibold text-slate-600">Budget</th>
              <th class="px-4 py-3 text-left font-semibold text-slate-600">Proposals</th>
              <th class="px-4 py-3 text-left font-semibold text-slate-600">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @jobs.each do |job| %>
              <tr class="hover:bg-slate-50 transition-colors">
                <td class="px-4 py-3 font-medium text-slate-900"><%= job.title %></td>
                <td class="px-4 py-3">
                  <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold <%= job.status == 'open' ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800' %>">
                    <%= job.status.titleize %>
                  </span>
                </td>
                <td class="px-4 py-3 font-medium text-slate-900">$<%= job.budget %></td>
                <td class="px-4 py-3"><span class="rounded-full bg-blue-100 px-2.5 py-1 text-xs font-semibold text-blue-800"><%= job.proposals.count %></span></td>
                <td class="px-4 py-3">
                  <div class="flex flex-wrap gap-2">
                    <%= link_to "View", job_path(job), class: "rounded-md bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-800 hover:bg-blue-200" %>
                    <%= link_to "Edit", edit_job_path(job), class: "rounded-md bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-800 hover:bg-amber-200" %>
                    <% if job.status == 'open' %>
                      <%= link_to "Close", close_job_path(job), method: :patch, class: "rounded-md bg-red-100 px-3 py-1 text-xs font-semibold text-red-800 hover:bg-red-200" %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

    
    <% else %>
      <div class="text-center py-8">
        <p class="text-slate-600 mb-4">No jobs posted yet.</p>
        <%= link_to "Post your first job", new_job_path, class: "inline-flex rounded-full bg-emerald-600 px-5 py-2 font-medium text-white hover:bg-emerald-700" %>
      </div>
    <% end %>
  </div>
</div>