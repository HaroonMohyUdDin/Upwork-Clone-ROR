<div class="space-y-6">
  <h1 class="text-2xl font-bold text-slate-900">Client Dashboard</h1>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <div class="rounded-xl border border-slate-200 bg-white p-5 text-center shadow-sm">
      <h5 class="text-sm font-medium text-slate-500">Posted Jobs</h5>
      <h2 class="mt-2 text-3xl font-bold text-slate-900"><%= @jobs.count %></h2>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5 text-center shadow-sm">
      <h5 class="text-sm font-medium text-slate-500">Active Jobs</h5>
      <h2 class="mt-2 text-3xl font-bold text-slate-900"><%= @active_jobs.count %></h2>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5 text-center shadow-sm">
      <h5 class="text-sm font-medium text-slate-500">Completed Jobs</h5>
      <h2 class="mt-2 text-3xl font-bold text-slate-900"><%= @completed_jobs.count %></h2>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5 text-center shadow-sm">
      <h5 class="text-sm font-medium text-slate-500">Total Spent</h5>
      <h2 class="mt-2 text-3xl font-bold text-slate-900">$<%= @total_spent %></h2>
    </div>
  </div>

  <div>
    <%= link_to "Post New Job", new_job_path, class: "inline-flex rounded-full bg-emerald-600 px-5 py-2 font-medium text-white hover:bg-emerald-700" %>
  </div>

  <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
    <h3 class="mb-4 text-xl font-semibold text-slate-900">Recent Jobs</h3>
    <% if @jobs.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
          <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
            <tr>
              <th class="px-3 py-3">Title</th>
              <th class="px-3 py-3">Status</th>
              <th class="px-3 py-3">Budget</th>
              <th class="px-3 py-3">Proposals</th>
              <th class="px-3 py-3">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @jobs.each do |job| %>
              <tr>
                <td class="px-3 py-3 font-medium text-slate-900"><%= job.title %></td>
                <td class="px-3 py-3"><span class="rounded-full bg-sky-100 px-2.5 py-1 text-xs font-semibold text-sky-800"><%= job.status %></span></td>
                <td class="px-3 py-3">$<%= job.budget %></td>
                <td class="px-3 py-3"><%= job.proposals.count %></td>
                <td class="px-3 py-3">
                  <div class="flex flex-wrap gap-2">
                    <%= link_to "View", job_path(job), class: "rounded-md bg-sky-100 px-3 py-1.5 text-xs font-semibold text-sky-800 hover:bg-sky-200" %>
                    <%= link_to "Edit", edit_job_path(job), class: "rounded-md bg-amber-100 px-3 py-1.5 text-xs font-semibold text-amber-800 hover:bg-amber-200" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-slate-600">No jobs posted yet. <%= link_to "Post your first job", new_job_path, class: "font-medium text-emerald-700 hover:text-emerald-800" %></p>
    <% end %>
  </div>
</div>