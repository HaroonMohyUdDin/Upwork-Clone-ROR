<div class="space-y-8">
  <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
    <div>
      <h1 class="text-3xl font-bold text-slate-900">Client Dashboard</h1>
      <p class="mt-2 text-sm text-slate-600">Manage your jobs, review proposals, and stay in touch with freelancers.</p>
    </div>

    <%= link_to "Post New Job", new_job_path, class: "inline-flex items-center justify-center rounded-full bg-emerald-600 px-5 py-2 font-semibold text-white hover:bg-emerald-700" %>
  </div>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-5">
    <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
      <h5 class="text-sm font-medium text-slate-500">Posted Jobs</h5>
      <h2 class="mt-2 text-3xl font-bold text-slate-900"><%= @jobs.count %></h2>
    </div>

    <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
      <h5 class="text-sm font-medium text-slate-500">Active Jobs</h5>
      <h2 class="mt-2 text-3xl font-bold text-emerald-600"><%= @active_jobs.count %></h2>
    </div>

    <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
      <h5 class="text-sm font-medium text-slate-500">Pending Proposals</h5>
      <h2 class="mt-2 text-3xl font-bold text-blue-600"><%= @pending_proposals.count %></h2>
    </div>

    <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
      <h5 class="text-sm font-medium text-slate-500">Active Contracts</h5>
      <h2 class="mt-2 text-3xl font-bold text-purple-600"><%= @active_contracts.count %></h2>
    </div>

    <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
      <h5 class="text-sm font-medium text-slate-500">Total Spent</h5>
      <h2 class="mt-2 text-3xl font-bold text-slate-900">$<%= @total_spent %></h2>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <%= link_to client_contracts_path, class: "rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:bg-slate-50" do %>
      <div class="text-sm font-medium text-slate-600">Active Contracts</div>
      <div class="mt-1 text-2xl font-bold text-slate-900"><%= @active_contracts.count %></div>
    <% end %>

    <%= link_to client_payments_path, class: "rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:bg-slate-50" do %>
      <div class="text-sm font-medium text-slate-600">This Month</div>
      <div class="mt-1 text-2xl font-bold text-slate-900">$<%= @month_spent %></div>
    <% end %>

    <%= link_to client_freelancers_path, class: "rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:bg-slate-50" do %>
      <div class="text-sm font-medium text-slate-600">Browse Talents</div>
      <div class="mt-1 text-2xl font-bold text-slate-900">→</div>
    <% end %>

    <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="text-sm font-medium text-slate-600">Pending Proposals</div>
      <div class="mt-1 text-2xl font-bold text-slate-900"><%= @pending_proposals.count %></div>
    </div>
  </div>

  <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
    <div class="mb-4 flex items-center justify-between">
      <div>
        <h2 class="text-xl font-semibold text-slate-900">Pending Proposals</h2>
        <p class="mt-1 text-sm text-slate-600">Review proposals submitted by freelancers for your jobs.</p>
      </div>
    </div>

    <% if @pending_proposals.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
          <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
            <tr>
              <th class="px-4 py-3">Freelancer</th>
              <th class="px-4 py-3">Job</th>
              <th class="px-4 py-3">Cover Letter</th>
              <th class="px-4 py-3">Submitted</th>
              <th class="px-4 py-3">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @pending_proposals.each do |proposal| %>
              <tr class="hover:bg-slate-50">
                <td class="px-4 py-3 font-medium text-slate-900">
                  <%= link_to proposal.user.name, user_path(proposal.user), class: "text-emerald-600 hover:text-emerald-700" %>
                </td>
                <td class="px-4 py-3 text-slate-700">
                  <%= link_to proposal.job.title, job_path(proposal.job), class: "hover:text-emerald-700" %>
                </td>
                <td class="px-4 py-3 text-slate-600">
                  <%= proposal.cover_letter.truncate(90) %>
                </td>
                <td class="px-4 py-3 text-slate-600">
                  <%= proposal.created_at.strftime("%B %d, %Y") %>
                </td>
                <td class="px-4 py-3">
                  <div class="flex flex-wrap gap-2">
                    <%= link_to "Accept", accept_job_proposal_path(proposal.job, proposal), method: :patch, class: "rounded-md bg-green-100 px-3 py-1.5 text-xs font-semibold text-green-800 hover:bg-green-200" %>
                    <%= link_to "Reject", reject_job_proposal_path(proposal.job, proposal), method: :patch, class: "rounded-md bg-red-100 px-3 py-1.5 text-xs font-semibold text-red-800 hover:bg-red-200" %>
                    <%= link_to "Message Freelancer", message_freelancer_job_proposal_path(proposal.job, proposal), method: :post, class: "rounded-md bg-blue-100 px-3 py-1.5 text-xs font-semibold text-blue-800 hover:bg-blue-200" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="rounded-lg border border-slate-200 bg-slate-50 p-4 text-slate-600">
        No pending proposals right now.
      </div>
    <% end %>
  </div>

  <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
    <div class="mb-4 flex items-center justify-between">
      <div>
        <h3 class="text-xl font-semibold text-slate-900">Recent Jobs</h3>
        <p class="mt-1 text-sm text-slate-600">Track the jobs you have posted.</p>
      </div>
    </div>

    <% if @jobs.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
          <thead class="bg-slate-50">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-slate-600">Title</th>
              <th class="px-4 py-3 text-left font-semibold text-slate-600">Status</th>
              <th class="px-4 py-3 text-left font-semibold text-slate-600">Budget</th>
              <th class="px-4 py-3 text-left font-semibold text-slate-600">Proposals</th>
              <th class="px-4 py-3 text-left font-semibold text-slate-600">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @jobs.each do |job| %>
              <tr class="hover:bg-slate-50 transition-colors">
                <td class="px-4 py-3 font-medium text-slate-900"><%= job.title %></td>
                <td class="px-4 py-3">
                  <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold <%= job.status == 'open' ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800' %>">
                    <%= job.status.titleize %>
                  </span>
                </td>
                <td class="px-4 py-3 font-medium text-slate-900">$<%= job.budget %></td>
                <td class="px-4 py-3">
                  <span class="rounded-full bg-blue-100 px-2.5 py-1 text-xs font-semibold text-blue-800">
                    <%= job.proposals.count %>
                  </span>
                </td>
                <td class="px-4 py-3">
                  <div class="flex flex-wrap gap-2">
                    <%= link_to "View", job_path(job), class: "rounded-md bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-800 hover:bg-blue-200" %>
                    <%= link_to "Edit", edit_job_path(job), class: "rounded-md bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-800 hover:bg-amber-200" %>
                    <% if job.status == 'open' %>
                      <%= link_to "Close", close_job_path(job), method: :patch, class: "rounded-md bg-red-100 px-3 py-1 text-xs font-semibold text-red-800 hover:bg-red-200" %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="py-8 text-center">
        <p class="mb-4 text-slate-600">No jobs posted yet.</p>
        <%= link_to "Post your first job", new_job_path, class: "inline-flex rounded-full bg-emerald-600 px-5 py-2 font-semibold text-white hover:bg-emerald-700" %>
      </div>
    <% end %>
  </div>
</div>