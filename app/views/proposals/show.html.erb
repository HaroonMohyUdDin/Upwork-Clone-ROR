<div class="space-y-6">
  <h2 class="text-2xl font-bold text-slate-900">Proposal Details</h2>

  <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
    <dl class="space-y-4">
      <div>
        <dt class="text-sm font-semibold text-slate-700">Job</dt>
        <dd class="mt-1 text-slate-600"><%= link_to @proposal.job.title, @proposal.job, class: "text-emerald-600 hover:text-emerald-700" %></dd>
      </div>
      <div>
        <dt class="text-sm font-semibold text-slate-700">Freelancer</dt>
        <dd class="mt-1 text-slate-600"><%= link_to @proposal.user.name, user_path(@proposal.user), class: "text-emerald-600 hover:text-emerald-700" %></dd>
      </div>
      <div>
        <dt class="text-sm font-semibold text-slate-700">Status</dt>
        <dd class="mt-1"><span class="inline-block rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-800"><%= @proposal.status %></span></dd>
      </div>
      <div>
        <dt class="text-sm font-semibold text-slate-700">Cover Letter</dt>
        <dd class="mt-1 text-slate-600"><%= @proposal.cover_letter %></dd>
      </div>
      <div>
        <dt class="text-sm font-semibold text-slate-700">Submitted</dt>
        <dd class="mt-1 text-sm text-slate-600"><%= @proposal.created_at.strftime("%B %d, %Y") %></dd>
      </div>
    </dl>
  </div>

  <% if current_user == @proposal.job.user %>
    <div class="flex flex-wrap gap-3">
      <%= link_to "Accept", accept_proposal_path(@proposal), method: :patch, class: "rounded-full bg-green-600 px-5 py-2 font-semibold text-white hover:bg-green-700" %>
      <%= link_to "Reject", reject_proposal_path(@proposal), method: :patch, class: "rounded-full bg-red-600 px-5 py-2 font-semibold text-white hover:bg-red-700" %>
    </div>
  <% end %>

  <%= link_to "Back to Job", @proposal.job, class: "inline-flex rounded-full border border-slate-300 px-5 py-2 font-semibold text-slate-700 hover:bg-slate-100" %>
</div>
