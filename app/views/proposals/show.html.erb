<div class="container">
  <h2>Proposal Details</h2>

  <div class="card">
    <div class="card-body">
      <h5><strong>Job:</strong> <%= link_to @proposal.job.title, @proposal.job %></h5>
      <h5><strong>Freelancer:</strong> <%= link_to @proposal.user.name, user_path(@proposal.user) %></h5>
      <p><strong>Status:</strong> <%= @proposal.status %></p>
      <p><strong>Cover Letter:</strong></p>
      <p><%= @proposal.cover_letter %></p>
      <p><strong>Submitted:</strong> <%= @proposal.created_at.strftime("%B %d, %Y") %></p>
    </div>
  </div>

  <% if current_user == @proposal.job.user %>
    <div class="mt-3">
      <%= link_to "Accept", accept_proposal_path(@proposal), method: :patch, class: "btn btn-success" %>
      <%= link_to "Reject", reject_proposal_path(@proposal), method: :patch, class: "btn btn-danger" %>
    </div>
  <% end %>

  <%= link_to "Back to Job", @proposal.job, class: "btn btn-secondary mt-2" %>
</div>
