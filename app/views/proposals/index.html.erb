<div class="space-y-4">
  <div>
    <h2 class="text-2xl font-bold text-slate-900">Proposals for <%= link_to @job.title, @job, class: "text-emerald-600 hover:text-emerald-700" %></h2>
  </div>

  <% if @proposals.any? %>
    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
          <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
            <tr>
              <th class="px-3 py-3">Freelancer</th>
              <th class="px-3 py-3">Cover Letter</th>
              <th class="px-3 py-3">Status</th>
              <th class="px-3 py-3">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @proposals.each do |proposal| %>
              <tr>
                <td class="px-3 py-3 font-medium text-slate-900"><%= link_to proposal.user.name, user_path(proposal.user), class: "text-emerald-600 hover:text-emerald-700" %></td>
                <td class="px-3 py-3 text-slate-600"><%= proposal.cover_letter.truncate(50) %></td>
                <td class="px-3 py-3"><span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-800"><%= proposal.status %></span></td>
                <td class="px-3 py-3">
                  <div class="flex flex-wrap gap-2">
                    <%= link_to "View", proposal, class: "rounded-md bg-sky-100 px-3 py-1.5 text-xs font-semibold text-sky-800 hover:bg-sky-200" %>
                    <% if current_user == @job.user %>
                      <%= link_to "Accept", accept_proposal_path(proposal), method: :patch, class: "rounded-md bg-green-100 px-3 py-1.5 text-xs font-semibold text-green-800 hover:bg-green-200" %>
                      <%= link_to "Reject", reject_proposal_path(proposal), method: :patch, class: "rounded-md bg-red-100 px-3 py-1.5 text-xs font-semibold text-red-800 hover:bg-red-200" %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
      <p class="text-slate-600">No proposals yet.</p>
    </div>
  <% end %>

  <%= link_to "Back to Job", @job, class: "inline-flex rounded-full border border-slate-300 px-5 py-2 font-semibold text-slate-700 hover:bg-slate-100" %>
</div>
