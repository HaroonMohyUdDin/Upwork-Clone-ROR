<div class="space-y-6">
  <h2 class="text-2xl font-bold text-slate-900">My Contracts</h2>

  <% if @contracts.any? %>
    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
          <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
            <tr>
              <th class="px-3 py-3">Job Title</th>
              <th class="px-3 py-3">Role</th>
              <th class="px-3 py-3">Status</th>
              <th class="px-3 py-3">Start Date</th>
              <th class="px-3 py-3">End Date</th>
              <th class="px-3 py-3">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @contracts.each do |contract| %>
              <tr>
                <td class="px-3 py-3 font-medium text-slate-900"><%= contract.job.title %></td>
                <td class="px-3 py-3">
                  <% if contract.freelancer_id == current_user.id %>
                    <span class="rounded-full bg-indigo-100 px-2.5 py-1 text-xs font-semibold text-indigo-800">Freelancer</span>
                  <% elsif contract.client_id == current_user.id %>
                    <span class="rounded-full bg-green-100 px-2.5 py-1 text-xs font-semibold text-green-800">Client</span>
                  <% end %>
                </td>
                <td class="px-3 py-3">
                  <% case contract.status %>
                    <% when 'active' %>
                      <span class="rounded-full bg-green-100 px-2.5 py-1 text-xs font-semibold text-green-800">Active</span>
                    <% when 'completed' %>
                      <span class="rounded-full bg-blue-100 px-2.5 py-1 text-xs font-semibold text-blue-800">Completed</span>
                    <% when 'cancelled' %>
                      <span class="rounded-full bg-red-100 px-2.5 py-1 text-xs font-semibold text-red-800">Cancelled</span>
                    <% else %>
                     <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-800"><%= (contract.status || 'active').capitalize %></span>
                    <% end %>
                </td>
                <td class="px-3 py-3 text-slate-600"><%= contract.created_at.strftime("%b %d, %Y") %></td>
                <td class="px-3 py-3 text-slate-600"><%= contract.end_date&.strftime("%b %d, %Y") || "—" %></td>
                <td class="px-3 py-3">
                  <div class="flex flex-wrap gap-2">
                    <%= link_to "View", contract_path(contract), class: "rounded-md bg-sky-100 px-3 py-1.5 text-xs font-semibold text-sky-800 hover:bg-sky-200" %>
                    <% if current_user.id == contract.client_id %>
                    <% if contract.status == 'active' %>
  <%= button_to "Complete", complete_contract_path(contract), method: :patch, class: "rounded-md bg-green-100 px-3 py-1.5 text-xs font-semibold text-green-800 hover:bg-green-200" %>
<% end %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="rounded-lg border border-blue-200 bg-blue-50 p-4 text-blue-800">
      <p class="mb-3">You don't have any contracts yet.</p>
      <%= link_to "Browse Jobs", jobs_path, class: "inline-flex rounded-full bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700" %>
    </div>
  <% end %>
</div>
