<div class="space-y-6">
  <h2 class="text-2xl font-bold text-slate-900">Contract Details</h2>

  <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
    <dl class="space-y-4">
      <div>
        <dt class="text-sm font-semibold text-slate-700">Job</dt>
        <dd class="mt-1 text-slate-600"><%= link_to @contract.job.title, job_path(@contract.job), class: "text-emerald-600 hover:text-emerald-700" %></dd>
      </div>
      <div>
        <dt class="text-sm font-semibold text-slate-700">Freelancer</dt>
        <dd class="mt-1 text-slate-600"><%= link_to @contract.freelancer.name, user_path(@contract.freelancer), class: "text-emerald-600 hover:text-emerald-700" %></dd>
      </div>
      <div>
        <dt class="text-sm font-semibold text-slate-700">Client</dt>
        <dd class="mt-1 text-slate-600"><%= link_to @contract.client.name, user_path(@contract.client), class: "text-emerald-600 hover:text-emerald-700" %></dd>
      </div>
      <div>
        <dt class="text-sm font-semibold text-slate-700">Status</dt>
        <dd class="mt-1"><span class="inline-block rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-800"><%= @contract.status.capitalize %></span></dd>
      </div>
      <% if @contract.end_date.present? %>
        <div>
          <dt class="text-sm font-semibold text-slate-700">End Date</dt>
          <dd class="mt-1 text-slate-600"><%= @contract.end_date.strftime('%B %d, %Y') %></dd>
        </div>
      <% end %>
    </dl>
  </div>

  <% if current_user.id == @contract.client_id %>
    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
      <h3 class="mb-4 text-lg font-semibold text-slate-900">Update Contract</h3>
      <%= form_with(model: @contract, local: true, class: "space-y-4") do |f| %>
        <div>
          <%= f.label :status, class: "mb-2 block text-sm font-medium text-slate-700" %>
          <%= f.select :status, Contract.statuses.keys.map { |s| [s.titleize, s] }, {}, class: "w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200" %>
        </div>
        <div>
          <%= f.label :end_date, class: "mb-2 block text-sm font-medium text-slate-700" %>
          <%= f.date_field :end_date, class: "w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200" %>
        </div>
        <div>
          <%= f.submit "Update Contract", class: "rounded-full bg-emerald-600 px-5 py-2 font-semibold text-white hover:bg-emerald-700" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <%= link_to "Back to Jobs", jobs_path, class: "inline-flex rounded-full border border-slate-300 px-5 py-2 font-semibold text-slate-700 hover:bg-slate-100" %>
</div>