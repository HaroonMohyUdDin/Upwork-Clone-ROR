<div class="space-y-6">
  <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900">Welcome to Upwork Clone</h1>

    <% if user_signed_in? %>
      <div class="mt-4 space-y-4">
        <div>
          <h2 class="text-xl font-semibold text-slate-900">Hello, <%= current_user.name %>!</h2>
          <p class="text-slate-600">Your role: <strong class="font-semibold text-slate-800"><%= current_user.role %></strong></p>
        </div>

        <div class="flex flex-wrap gap-2">
          <% if current_user.client? %>
            <%= link_to "Post a Job", new_job_path, class: "rounded-full bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700" %>
          <% elsif current_user.freelancer? %>
            <%= link_to "View Jobs", jobs_path, class: "rounded-full bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700" %>
          <% end %>

          <%= link_to "View All Jobs", jobs_path, class: "rounded-full bg-sky-100 px-4 py-2 text-sm font-medium text-sky-800 hover:bg-sky-200" %>
          <%= link_to "Messages", conversations_path, class: "rounded-full bg-teal-100 px-4 py-2 text-sm font-medium text-teal-800 hover:bg-teal-200" %>
          <%= link_to(current_user.freelancer? ? "My Freelancer Dashboard" : "My Client Dashboard", current_user.freelancer? ? freelancer_dashboard_path : client_dashboard_path, class: "rounded-full border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100") %>
          <%= link_to "Sign Out", destroy_user_session_path, method: :delete, class: "rounded-full bg-rose-100 px-4 py-2 text-sm font-medium text-rose-800 hover:bg-rose-200" %>
        </div>
      </div>
    <% else %>
      <div class="mt-4 flex flex-wrap items-center gap-3">
        <p class="text-slate-600">Get started by signing up!</p>
        <%= link_to "Sign Up", new_user_registration_path, class: "rounded-full bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700" %>
        <%= link_to "Sign In", new_user_session_path, class: "rounded-full border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100" %>
      </div>
    <% end %>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <h3 class="mb-4 text-xl font-semibold text-slate-900">Recent Jobs</h3>
    <% if @jobs.present? && @jobs.any? %>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <% @jobs.each do |job| %>
          <article class="rounded-xl border border-slate-200 bg-white p-4">
            <h5 class="text-lg font-semibold text-slate-900"><%= link_to job.title, job_path(job), class: "hover:text-emerald-700" %></h5>
            <p class="mt-2 text-sm text-slate-600"><%= job.description.truncate(100) %></p>
            <p class="mt-2 text-sm text-slate-700"><strong>Budget:</strong> $<%= job.budget %></p>
            <p class="text-sm text-slate-700"><strong>Category:</strong> <%= job.category %></p>
            <p class="text-sm text-slate-700"><strong>Posted by:</strong> <%= link_to job.user.name, user_path(job.user), class: "text-emerald-700 hover:text-emerald-800" %></p>
            <%= link_to "View Details", job_path(job), class: "mt-3 inline-flex rounded-md bg-emerald-600 px-3 py-2 text-xs font-semibold text-white hover:bg-emerald-700" %>
          </article>
        <% end %>
      </div>
    <% else %>
      <p class="text-slate-600">No jobs available yet.</p>
    <% end %>
  </section>
</div>
