<% content_for :title, "Upwork Clone - Find Freelancers & Jobs" %>

<div class="space-y-12">
  <!-- Hero Section -->
  <section class="py-12 md:py-20">
    <div class="text-center max-w-3xl mx-auto">
      <h1 class="section-title mb-4">
        Connect with Top Talent or Find Your Next Project
      </h1>
      <p class="section-subtitle mb-8">
        A modern freelance marketplace connecting clients with talented professionals worldwide.
      </p>

      <% if !user_signed_in? %>
        <div class="flex gap-4 justify-center flex-wrap">
          <%= link_to "Sign Up as Freelancer", new_user_registration_path, class: "btn btn-primary" %>
          <%= link_to "Sign Up as Client", new_user_registration_path, class: "btn btn-secondary" %>
        </div>
      <% else %>
        <% if current_user.freelancer? %>
          <%= link_to "Browse Jobs", jobs_path, class: "btn btn-primary" %>
        <% else %>
          <%= link_to "Post Your First Job", new_job_path, class: "btn btn-primary" %>
        <% end %>
      <% end %>
    </div>
  </section>

  <% if !user_signed_in? %>
    <!-- Features Section -->
    <section class="py-12">
      <h2 class="section-title text-center mb-12">Why Choose Upwork?</h2>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="card hover-lift">
          <div class="card-body">
            <div class="w-12 h-12 bg-emerald-100 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="font-bold text-gray-900 mb-2">Fast & Easy</h3>
            <p class="text-gray-600">Get started in minutes with our simple onboarding process.</p>
          </div>
        </div>

        <div class="card hover-lift">
          <div class="card-body">
            <div class="w-12 h-12 bg-emerald-100 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-bold text-gray-900 mb-2">Secure Payments</h3>
            <p class="text-gray-600">All transactions are protected with escrow protection.</p>
          </div>
        </div>

        <div class="card hover-lift">
          <div class="card-body">
            <div class="w-12 h-12 bg-emerald-100 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h-2m0 0H8m4 0v4m0-4V8m0 4h6m0 0h2m-2 0v4m0-4V8" />
              </svg>
            </div>
            <h3 class="font-bold text-gray-900 mb-2">24/7 Support</h3>
            <p class="text-gray-600">Our team is always here to help you succeed.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="py-12 bg-emerald-50 rounded-lg">
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <p class="text-4xl font-bold text-emerald-600 mb-2">10K+</p>
          <p class="text-gray-600">Active Freelancers</p>
        </div>
        <div class="text-center">
          <p class="text-4xl font-bold text-emerald-600 mb-2">5K+</p>
          <p class="text-gray-600">Projects Completed</p>
        </div>
        <div class="text-center">
          <p class="text-4xl font-bold text-emerald-600 mb-2">$2M+</p>
          <p class="text-gray-600">Money Transacted</p>
        </div>
      </div>
    </section>
  <% end %>

  <!-- Recent Jobs Section -->
  <% if @jobs.any? %>
    <section class="py-12">
      <h2 class="section-title mb-8">Recent Jobs</h2>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @jobs.each do |job| %>
          <div class="card hover-lift">
            <div class="card-body">
              <div class="flex items-start justify-between mb-3">
                <h3 class="font-bold text-gray-900 flex-1"><%= link_to job.title, job_path(job), class: "hover:text-emerald-600" %></h3>
                <span class="badge badge-primary"><%= job.status.humanize %></span>
              </div>

              <p class="text-sm text-gray-600 mb-3 line-clamp-2"><%= job.description %></p>

              <div class="flex items-center justify-between mb-3 text-sm">
                <span class="font-semibold text-emerald-600">$<%= job.budget %></span>
                <span class="text-gray-500"><%= job.proposals.count %> proposals</span>
              </div>

              <div class="flex gap-2">
                <%= link_to "View Job", job_path(job), class: "btn btn-sm btn-primary flex-1" %>
                <% if user_signed_in? && current_user.freelancer? && current_user != job.user %>
                  <%= link_to "Propose", new_job_proposal_path(job), class: "btn btn-sm btn-secondary flex-1" %>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>
</div>