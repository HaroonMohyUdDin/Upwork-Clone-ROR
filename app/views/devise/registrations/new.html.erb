<div class="mx-auto max-w-md space-y-6 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
  <div>
    <h2 class="text-2xl font-bold text-slate-900">Create Account</h2>
    <p class="mt-2 text-sm text-slate-600">Join Upwork as a freelancer or client</p>
  </div>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), local: true, class: "space-y-5") do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :name, class: "mb-2 block text-sm font-medium text-slate-700" %>
      <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200" %>
    </div>

    <div>
      <%= f.label :role, class: "mb-2 block text-sm font-medium text-slate-700" %>
      <%= f.select :role, [['Freelancer', 'freelancer'], ['Client', 'client']], { prompt: "Choose a role" }, class: "w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200" %>
    </div>

    <div>
      <%= f.label :email, class: "mb-2 block text-sm font-medium text-slate-700" %>
      <%= f.email_field :email, autocomplete: "email", class: "w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200" %>
    </div>

    <div>
      <%= f.label :password, class: "mb-2 block text-sm font-medium text-slate-700" %>
      <% if @minimum_password_length %>
        <p class="mb-2 text-xs text-slate-500"><%= @minimum_password_length %> characters minimum</p>
      <% end %>
      <%= f.password_field :password, autocomplete: "new-password", class: "w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200" %>
    </div>

    <div>
      <%= f.label :password_confirmation, class: "mb-2 block text-sm font-medium text-slate-700" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200" %>
    </div>

    <div class="pt-2">
      <%= f.submit "Sign up", class: "w-full rounded-full bg-emerald-600 px-4 py-2 font-semibold text-white hover:bg-emerald-700" %>
    </div>
  <% end %>

  <div class="border-t border-slate-200 pt-4 text-center text-sm">
    <%= render "devise/shared/links" %>
  </div>
</div>
