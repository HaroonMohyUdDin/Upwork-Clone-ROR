<div class="mx-auto max-w-md space-y-6 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
  <div>
    <h2 class="text-2xl font-bold text-slate-900">Sign in</h2>
    <p class="mt-2 text-sm text-slate-600">Access your Upwork account</p>
  </div>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), local: true, class: "space-y-5") do |f| %>
    <div>
      <%= f.label :email, class: "mb-2 block text-sm font-medium text-slate-700" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200" %>
    </div>

    <div>
      <%= f.label :password, class: "mb-2 block text-sm font-medium text-slate-700" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="flex items-center">
        <%= f.check_box :remember_me, class: "rounded border-slate-300" %>
        <%= f.label :remember_me, class: "ml-2 text-sm text-slate-700" %>
      </div>
    <% end %>

    <div class="pt-2">
      <%= f.submit "Sign in", class: "w-full rounded-full bg-emerald-600 px-4 py-2 font-semibold text-white hover:bg-emerald-700" %>
    </div>
  <% end %>

  <div class="border-t border-slate-200 pt-4 text-center text-sm">
    <%= render "devise/shared/links" %>
  </div>
</div>
