<div class="container">
  <h2>Leave a Review</h2>

  <div class="card">
    <div class="card-body">
      <p><strong>Job:</strong> <%= @job.title %></p>
      <p><strong>Posted by:</strong> <%= @job.user.name %></p>

      <%= form_with(model: [@job, @review], local: true) do |f| %>
        <% if @review.errors.any? %>
          <div class="alert alert-danger">
            <h4><%= pluralize(@review.errors.count, "error") %> prohibited this review:</h4>
            <ul>
              <% @review.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="form-group mb-3">
          <%= f.label :rating %>
          <%= f.select :rating, (1..5).map { |i| [i, i] }, { prompt: "Select rating" }, class: "form-control" %>
        </div>

        <div class="form-group mb-3">
          <%= f.label :comment %>
          <%= f.text_area :comment, rows: 5, class: "form-control", placeholder: "Share your experience..." %>
        </div>

        <div class="form-group mb-3">
          <%= f.label :reviewee_id, "Review for" %>
          <%= f.select :reviewee_id, [[current_user == @job.user ? "Freelancer" : "Client", @job.user_id]], {}, class: "form-control" %>
        </div>

        <%= f.submit "Submit Review", class: "btn btn-primary" %>
      <% end %>
    </div>
  </div>

  <%= link_to "Back to Job", @job, class: "btn btn-secondary mt-3" %>
</div>
