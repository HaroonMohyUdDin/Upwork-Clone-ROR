<div class="mx-auto max-w-2xl space-y-6">
  <h2 class="text-2xl font-bold text-slate-900">Leave a Review</h2>

  <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
    <div class="mb-6 border-b border-slate-200 pb-4">
      <p class="text-sm text-slate-600"><strong>Job:</strong> <%= @job.title %></p>
      <p class="mt-1 text-sm text-slate-600"><strong>Posted by:</strong> <%= @job.user.name %></p>
    </div>

    <%= form_with(model: [@job, @review], local: true, class: "space-y-5") do |f| %>
      <% if @review.errors.any? %>
        <div class="rounded-lg border border-red-200 bg-red-50 p-4 text-red-800">
          <h4 class="mb-2 font-semibold"><%= pluralize(@review.errors.count, "error") %> prohibited this review:</h4>
          <ul class="list-disc space-y-1 pl-5 text-sm">
            <% @review.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :rating, class: "mb-2 block text-sm font-medium text-slate-700" %>
        <%= f.select :rating, (1..5).map { |i| ["#{i} Star#{i > 1 ? 's' : ''} ⭐", i] }, { prompt: "Select rating" }, class: "w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200" %>
      </div>

      <div>
        <%= f.label :comment, class: "mb-2 block text-sm font-medium text-slate-700" %>
        <%= f.text_area :comment, rows: 5, class: "w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200", placeholder: "Share your experience..." %>
      </div>

      <div>
        <%= f.label :reviewee_id, "Review for", class: "mb-2 block text-sm font-medium text-slate-700" %>
        <%= f.select :reviewee_id, [[current_user == @job.user ? "Freelancer" : "Client", @job.user_id]], {}, class: "w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200" %>
      </div>

      <div class="flex flex-wrap gap-3 pt-2">
        <%= f.submit "Submit Review", class: "rounded-full bg-emerald-600 px-5 py-2 font-semibold text-white hover:bg-emerald-700" %>
        <%= link_to "Back to Job", @job, class: "rounded-full border border-slate-300 px-5 py-2 font-semibold text-slate-700 hover:bg-slate-100" %>
      </div>
    <% end %>
  </div>
</div>
