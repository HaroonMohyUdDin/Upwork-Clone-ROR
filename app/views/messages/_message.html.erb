<% mine = message.sender_id == current_user.id %>

<div class="flex <%= mine ? 'justify-end' : 'justify-start' %>">

  <div class="flex max-w-[75%] items-end gap-3 <%= mine ? 'flex-row-reverse' : '' %>">

    <!-- Avatar -->
    <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full <%= mine ? 'bg-emerald-600 text-white' : 'bg-slate-300 text-slate-700' %> text-xs font-bold shadow-sm">
      <%= message.sender.name.first.upcase %>
    </div>

    <!-- Message Content -->
    <div>

      <!-- Sender Name -->
      <p class="mb-1 px-1 text-xs font-medium text-slate-500 <%= mine ? 'text-right' : '' %>">
        <%= mine ? 'You' : message.sender.name %>
      </p>

      <!-- Bubble -->
      <div class="<%= mine ? 'bg-emerald-600 text-white rounded-br-md' : 'bg-white border border-slate-200 text-slate-900 rounded-bl-md' %> rounded-2xl px-4 py-3 shadow-sm">

        <p class="text-sm leading-relaxed break-words">
          <%= message.body %>
        </p>
      </div>

      <!-- Time -->
      <p class="mt-1 px-1 text-[11px] text-slate-400 <%= mine ? 'text-right' : '' %>">
        <%= message.created_at.strftime("%I:%M %p") %>
      </p>

    </div>
  </div>
</div>