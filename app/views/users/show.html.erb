<div class="space-y-6">
  <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
    <div class="mb-4 flex items-start justify-between">
      <div>
        <h2 class="text-2xl font-bold text-slate-900"><%= @user.name %></h2>
        <p class="mt-2 text-sm text-slate-600"><strong>Role:</strong> <%= @user.role&.titleize || 'Not set' %></p>
      </div>
      <% if current_user != @user %>
        <%= link_to "Message", conversations_path(receiver_id: @user.id), method: :post, class: "rounded-full bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700" %>
      <% end %>
    </div>
    
    <dl class="space-y-2 border-t border-slate-200 pt-4 text-sm">
      <div>
        <dt class="font-semibold text-slate-700">Email</dt>
        <dd class="text-slate-600"><%= @user.email %></dd>
      </div>
      <% if @user.bio.present? %>
        <div>
          <dt class="font-semibold text-slate-700">Bio</dt>
          <dd class="text-slate-600"><%= @user.bio %></dd>
        </div>
      <% end %>
      <% if @user.freelancer? && @user.hourly_rate.present? %>
        <div>
          <dt class="font-semibold text-slate-700">Hourly Rate</dt>
          <dd class="text-slate-600">$<%= @user.hourly_rate %>/hr</dd>
        </div>
      <% end %>
    </dl>
  </div>

  <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
    <div class="mb-4 flex items-center justify-between">
      <h3 class="text-xl font-semibold text-slate-900">Reviews (<%= @user.review_count %>)</h3>
      <span class="rounded-full bg-blue-100 px-3 py-1 text-sm font-semibold text-blue-800"><%= @user.average_rating %>/5 ⭐</span>
    </div>

    <% if @reviews.any? %>
      <div class="space-y-4">
        <% @reviews.each do |review| %>
          <div class="border-b border-slate-200 pb-4 last:border-0">
            <div class="mb-2 flex items-center justify-between">
              <h6 class="font-medium text-slate-900"><%= link_to review.reviewer.name, user_path(review.reviewer), class: "text-emerald-600 hover:text-emerald-700" %></h6>
              <span class="text-sm">
                <% review.rating.times do %>
                  ⭐
                <% end %>
              </span>
            </div>
            <p class="text-sm text-slate-600"><%= review.comment %></p>
            <p class="mt-2 text-xs text-slate-500"><%= review.created_at.strftime("%B %d, %Y") %></p>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-slate-600">No reviews yet.</p>
    <% end %>
  </div>

  <%= link_to "Back to Jobs", jobs_path, class: "inline-flex rounded-full border border-slate-300 px-5 py-2 font-semibold text-slate-700 hover:bg-slate-100" %>
</div>
