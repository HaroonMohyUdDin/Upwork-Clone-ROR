<div class="mx-auto max-w-2xl rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
  <h1 class="mb-6 text-2xl font-bold text-slate-900">Post a New Job</h1>

  <%= form_with(model: @job, local: true, class: "space-y-5") do |form| %>
    <% if @job.errors.any? %>
      <div class="rounded-lg border border-red-200 bg-red-50 p-4 text-red-800">
        <h2 class="mb-2 font-semibold"><%= pluralize(@job.errors.count, "error") %> prohibited this job from being saved:</h2>
        <ul class="list-disc space-y-1 pl-5 text-sm">
          <% @job.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :title, class: "mb-2 block text-sm font-medium text-slate-700" %>
      <%= form.text_field :title, class: "w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200" %>
    </div>

    <div>
      <%= form.label :description, class: "mb-2 block text-sm font-medium text-slate-700" %>
      <%= form.text_area :description, rows: 5, class: "w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200" %>
    </div>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
      <div>
        <%= form.label :budget, class: "mb-2 block text-sm font-medium text-slate-700" %>
        <%= form.number_field :budget, step: 0.01, class: "w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200" %>
      </div>

      <div>
        <%= form.label :category, class: "mb-2 block text-sm font-medium text-slate-700" %>
        <%= form.text_field :category, class: "w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200" %>
      </div>
    </div>

    <div>
      <%= form.label :deadline, class: "mb-2 block text-sm font-medium text-slate-700" %>
      <%= form.datetime_field :deadline, class: "w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200" %>
    </div>

    <div class="flex flex-wrap gap-3 pt-2">
      <%= form.submit "Post Job", class: "rounded-full bg-emerald-600 px-5 py-2 font-semibold text-white hover:bg-emerald-700" %>
      <%= link_to "Back", jobs_path, class: "rounded-full border border-slate-300 px-5 py-2 font-semibold text-slate-700 hover:bg-slate-100" %>
    </div>
  <% end %>
</div>