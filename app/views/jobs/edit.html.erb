<div class="mx-auto max-w-2xl space-y-6 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
  <div>
    <h2 class="text-2xl font-bold text-slate-900">Edit Job</h2>
    <p class="mt-2 text-sm text-slate-600">Update your job details</p>
  </div>

  <%= form_with(model: @job, local: true, class: "space-y-5") do |f| %>
    <% if @job.errors.any? %>
      <div class="rounded-lg border border-red-200 bg-red-50 p-4">
        <h3 class="font-semibold text-red-900 mb-2"><%= pluralize(@job.errors.count, "error") %> prohibited this job:</h3>
        <ul class="space-y-1 text-sm text-red-800">
          <% @job.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :title, class: "mb-2 block text-sm font-medium text-slate-700" %>
      <%= f.text_field :title, class: "w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200" %>
    </div>

    <div>
      <%= f.label :description, class: "mb-2 block text-sm font-medium text-slate-700" %>
      <%= f.text_area :description, rows: 5, class: "w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200" %>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= f.label :category, class: "mb-2 block text-sm font-medium text-slate-700" %>
        <%= f.select :category, 
          ["Web Development", "Mobile App", "Design", "Writing", "Marketing", "Data Entry", "Other"], 
          {}, 
          class: "w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200" %>
      </div>

      <div>
        <%= f.label :budget, "Budget ($)", class: "mb-2 block text-sm font-medium text-slate-700" %>
        <%= f.number_field :budget, step: 0.01, class: "w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200" %>
      </div>
    </div>

    <div>
      <%= f.label :deadline, class: "mb-2 block text-sm font-medium text-slate-700" %>
      <%= f.datetime_field :deadline, class: "w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200" %>
    </div>

    <div>
      <%= f.label :status, class: "mb-2 block text-sm font-medium text-slate-700" %>
      <%= f.select :status, 
        [['Open', 'open'], ['In Progress', 'in_progress'], ['Closed', 'closed']], 
        {}, 
        class: "w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200" %>
    </div>

    <div class="flex gap-3 pt-4">
      <%= f.submit "Update Job", class: "rounded-full bg-emerald-600 px-6 py-3 font-semibold text-white hover:bg-emerald-700" %>
      <%= link_to "Cancel", job_path(@job), class: "rounded-full border border-slate-300 px-6 py-3 font-semibold text-slate-700 hover:bg-slate-50" %>
    </div>
  <% end %>
</div>