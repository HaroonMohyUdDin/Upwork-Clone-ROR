<div class="container">
  <h1><%= @job.title %></h1>
  
  <div class="job-details">
    <p><strong>Description:</strong> <%= @job.description %></p>
    <p><strong>Budget:</strong> $<%= @job.budget %></p>
    <p><strong>Category:</strong> <%= @job.category %></p>
    <p><strong>Status:</strong> <%= @job.status %></p>
    <p><strong>Posted by:</strong> <%= @job.user.name %></p>
    <p><strong>Posted on:</strong> <%= @job.created_at.strftime("%B %d, %Y") %></p>
  </div>

  <% if user_signed_in? && current_user.freelancer? && current_user != @job.user %>
    <h3>Submit a Proposal</h3>
    <%= form_with(model: [@job, @job.proposals.build], local: true) do |form| %>
      <div class="form-group">
        <%= form.label :cover_letter %>
        <%= form.text_area :cover_letter, rows: 5, class: "form-control" %>
      </div>
      <%= form.submit "Submit Proposal", class: "btn btn-success" %>
    <% end %>
  <% end %>

  <h3>Proposals (<%= @proposals.count %>)</h3>
  <% if user_signed_in? && current_user == @job.user %>
    <%= link_to "View All Proposals", job_proposals_path(@job), class: "btn btn-info mb-3" %>
  <% end %>

  <% if @proposals.any? %>
    <% @proposals.each do |proposal| %>
      <div class="card mb-3">
        <div class="card-body">
          <h6><strong>From:</strong> <%= link_to proposal.user.name, user_path(proposal.user) %></h6>
          <p><strong>Status:</strong> <%= proposal.status %></p>
          <p><%= proposal.cover_letter %></p>
          <small class="text-muted"><%= proposal.created_at.strftime("%B %d, %Y") %></small>
          <br>
          <% if user_signed_in? %>
            <%= link_to "View Proposal", proposal, class: "btn btn-sm btn-info" %>
            <% if current_user != proposal.user %>
              <%= link_to "Message", conversations_path(receiver_id: proposal.user.id), method: :post, class: "btn btn-sm btn-primary" %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <p>No proposals yet.</p>
  <% end %>

  <% if user_signed_in? && current_user == @job.user %>
    <div class="mt-4">
      <%= link_to "Leave Review", new_job_review_path(@job), class: "btn btn-warning" %>
      <%= link_to "Edit", edit_job_path(@job), class: "btn btn-warning" %>
      <%= link_to "Delete", job_path(@job), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger" %>
    </div>
  <% end %>

  <%= link_to "Back to Jobs", jobs_path, class: "btn btn-secondary mt-3" %>
</div>