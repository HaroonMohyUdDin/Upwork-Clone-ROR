<div class="space-y-4">
  <h2 class="text-2xl font-bold text-slate-900">Messages</h2>

  <% if @conversations.any? %>
    <div class="space-y-2">
      <% @conversations.each do |conversation| %>
        <% other_user = conversation.sender == current_user ? conversation.receiver : conversation.sender %>
        <%= link_to conversation_path(conversation), class: "block rounded-lg border border-slate-200 bg-white p-4 hover:bg-slate-50" do %>
          <div class="flex items-center justify-between">
            <p class="font-medium text-slate-900"><%= other_user.name %></p>
            <span class="text-xs text-slate-500"><%= conversation.updated_at.strftime("%b %d, %I:%M %p") %></span>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
      <p class="text-slate-600">No conversations yet.</p>
    </div>
  <% end %>
</div>
